# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
LOG_LEVEL=info

# ─── Database ─────────────────────────────────────────────────────────────────
# Neon: Use pooled URL for the app runtime
DATABASE_URL=postgresql://neondb_owner:<password>@<endpoint>-pooler.<region>.neon.tech/<dbname>?sslmode=require&channel_binding=require
# Neon: Use direct (non-pooled) URL for Prisma migrations (prisma migrate dev)
# DIRECT_URL=postgresql://neondb_owner:<password>@<endpoint>.<region>.neon.tech/<dbname>?sslmode=require
# Local Docker alternative:
# DATABASE_URL=postgresql://ailms_user:ailms_password@localhost:5432/ailms_db?schema=public

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT Secrets (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_ACCESS_SECRET=your_super_secret_access_key_minimum_32_chars_change_this_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_key_minimum_32_chars_change_this_in_production
JWT_EMAIL_SECRET=your_super_secret_email_key_minimum_32_chars_change_this_in_production

# ─── CORS & Client ────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
EMAIL_FROM=noreply@ailms.dev

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ─── Cloudinary ───────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── Security ─────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
