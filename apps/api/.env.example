# ─── Railway Environment Variables (Copy into Railway Dashboard) ───

PORT=5000
NODE_ENV=production

# ─── CORS ───
CORS_ORIGINS=https://your-app.vercel.app

# ─── Database (Neon.tech / Railway Postgres) ───
DATABASE_URL=postgresql://user:password@ep-xyz.neon.tech/ailms_db?sslmode=require

# ─── Redis (Upstash / Railway Redis) ───
REDIS_URL=rediss://default:password@xyz.upstash.io:6379

# ─── Authentication Secrets ───
JWT_SECRET=super_secret_jwt_key_change_in_production_32chars
JWT_REFRESH_SECRET=super_secret_refresh_key_change_in_production_32chars

# ─── AI Integrations ───
OPENAI_API_KEY=sk-proj-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# ─── Email / SMTP (Optional) ───
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="AI-LMS Platform <noreply@ailms.edu>"
